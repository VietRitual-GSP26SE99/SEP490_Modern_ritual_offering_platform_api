"\r\n\u003c!DOCTYPE html\u003e\r\n\u003chtml lang=\"vi\"\u003e\r\n\u003chead\u003e\n\u003cscript type=\"importmap\"\u003e\r\n{\r\n  \"imports\": {\r\n    \"react/\": \"https://esm.sh/react@^19.2.3/\",\r\n    \"react\": \"https://esm.sh/react@^19.2.3\",\r\n    \"react-dom/\": \"https://esm.sh/react-dom@^19.2.3/\",\r\n    \"@google/genai\": \"https://esm.sh/@google/genai@^1.35.0\"\r\n  }\r\n}\r\n\u003c/script\u003e\n  \u003cscript type=\"module\"\u003eimport { injectIntoGlobalHook } from \"/@react-refresh\";\ninjectIntoGlobalHook(window);\nwindow.$RefreshReg$ = () =\u003e {};\nwindow.$RefreshSig$ = () =\u003e (type) =\u003e type;\u003c/script\u003e\n\n  \u003cscript type=\"module\" src=\"/@vite/client\"\u003e\u003c/script\u003e\n\r\n    \u003cmeta charset=\"UTF-8\"\u003e\r\n    \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\r\n    \u003ctitle\u003eModern Ritual Offering\u003c/title\u003e\r\n    \u003cscript src=\"https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio\"\u003e\u003c/script\u003e\r\n    \u003clink href=\"https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;900\u0026family=Playfair+Display:ital,wght@0,700;0,900;1,700\u0026display=swap\" rel=\"stylesheet\"\u003e\r\n    \u003clink href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1\u0026display=swap\" rel=\"stylesheet\" /\u003e\r\n    \u003cscript\u003e\r\n        tailwind.config = {\r\n            theme: {\r\n                extend: {\r\n                    colors: {\r\n                        \u0027primary\u0027: \u0027#000000\u0027,\r\n                        \u0027gold\u0027: \u0027#000000\u0027,\r\n                        \u0027gold-light\u0027: \u0027#F5F5F5\u0027,\r\n                        \u0027ritual-bg\u0027: \u0027#FFFFFF\u0027,\r\n                    },\r\n                    fontFamily: {\r\n                        sans: [\u0027Be Vietnam Pro\u0027, \u0027sans-serif\u0027],\r\n                        display: [\u0027Playfair Display\u0027, \u0027serif\u0027],\r\n                    },\r\n                }\r\n            }\r\n        }\r\n    \u003c/script\u003e\r\n    \u003cstyle\u003e\n        .material-symbols-outlined {\n            font-variation-settings: \u0027FILL\u0027 0, \u0027wght\u0027 300, \u0027GRAD\u0027 0, \u0027opsz\u0027 24;\n        }\n        body {\n            background-color: #FFFFFF;\n        }\n        \n        /* Cart Dropdown Animation */\n        @keyframes slideDown {\n            from {\n                opacity: 0;\n                transform: translateY(-10px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        .animate-slideDown {\n            animation: slideDown 0.2s ease-out;\n        }\n    \u003c/style\u003e\r\n\r\n\u003clink rel=\"stylesheet\" href=\"/index.css\"\u003e\r\n\u003c/head\u003e\r\n\u003cbody\u003e\r\n    \u003cdiv id=\"root\"\u003e\u003c/div\u003e\r\n\u003cscript type=\"module\" src=\"/index.tsx?t=1773651709980\"\u003e\u003c/script\u003e\r\n\u003c/body\u003e\r\n\u003c/html\u003e\r\n"
